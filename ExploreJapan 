<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no, viewport-fit=cover">
  <title>Explore Japan · Sakura Dining</title>

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link rel="preconnect" href="https://unpkg.com">

  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@400;500&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">

  <!-- model-viewer loaded as module — same as menu code -->
  <script type="module" src="https://unpkg.com/@google/model-viewer/dist/model-viewer.min.js"></script>

  <style>
    :root {
      --ink:    #080604;
      --paper:  #F0E8D5;
      --yama:   #B8973A;
      --yama2:  #D4AE52;
      --beni:   #7A2E1E;
      --ff-en:  'Cormorant Garamond', serif;
      --ff-ui:  'DM Sans', sans-serif;
    }

    *, *::before, *::after { box-sizing: border-box; }

    body {
      margin: 0;
      background-color: var(--ink);
      color: var(--paper);
      font-family: var(--ff-ui);
      height: 100svh;
      overflow: hidden;
      display: flex;
      flex-direction: column;
    }

    /* ─── Spin keyframe (needed for button loading state) ── */
    @keyframes spin { to { transform: rotate(360deg); } }

    /* ─── Header ─────────────────────────────── */
    .nav-header {
      padding: max(env(safe-area-inset-top), 20px) 20px 16px;
      text-align: center;
      border-bottom: 1px solid rgba(184,151,58,0.2);
      flex-shrink: 0;
    }
    .nav-header h1 {
      font-family: var(--ff-en);
      font-size: clamp(24px, 6vw, 36px);
      margin: 0;
      color: var(--yama2);
      letter-spacing: 0.1em;
    }
    .nav-header p {
      font-size: 9px;
      text-transform: uppercase;
      letter-spacing: 0.3em;
      opacity: 0.5;
      margin: 4px 0 0;
    }

    /* ─── Scroll Grid ─────────────────────────── */
    .explorer-grid {
      flex: 1;
      display: flex;
      align-items: center;
      overflow-x: auto;
      overflow-y: hidden;
      padding: 20px 16px;
      gap: 16px;
      scroll-snap-type: x mandatory;
      -webkit-overflow-scrolling: touch;
      overscroll-behavior-x: contain;
      scrollbar-width: none;
    }
    .explorer-grid::-webkit-scrollbar { display: none; }

    /* ─── Card ────────────────────────────────── */
    .landmark-card {
      flex: 0 0 min(85vw, 360px);
      height: min(62vh, 520px);
      background: #0e0c0a;
      border: 1px solid rgba(184,151,58,0.25);
      border-radius: 14px;
      position: relative;
      scroll-snap-align: center;
      display: flex;
      flex-direction: column;
      overflow: hidden;
      will-change: transform;
      transform: translateZ(0);
    }

    /* ─── Thumbnail / Viewer Wrap ─────────────── */
    .thumb-wrap {
      flex: 1;
      position: relative;
      overflow: hidden;
      background: radial-gradient(ellipse at 50% 60%, #1a150a 0%, #080604 100%);
    }

    /* Photo shown immediately — same pattern as menu code */
    .thumb-photo {
      position: absolute;
      inset: 0;
      display: flex;
      align-items: center;
      justify-content: center;
      overflow: hidden;
      z-index: 1;
    }
    .thumb-photo img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
    }

    /* ─── "View on Table" AR launch button ───── */
    /* Sits over the photo, same idea as menu's mv-ar-btn-wrap */
    .ar-launch-wrap {
      position: absolute;
      bottom: 14px;
      left: 50%;
      transform: translateX(-50%);
      z-index: 6;
    }
    .ar-launch-btn {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      background: #000;
      color: #fff;
      border: none;
      border-radius: 24px;
      padding: 11px 22px;
      font-family: var(--ff-ui);
      font-size: 13px;
      font-weight: 600;
      letter-spacing: 0.05em;
      cursor: pointer;
      white-space: nowrap;
      min-height: 44px;
      box-shadow: 0 4px 16px rgba(184,134,11,0.35);
      transition: opacity 0.15s, transform 0.12s;
      -webkit-tap-highlight-color: transparent;
    }
    .ar-launch-btn:active { transform: scale(0.96); opacity: 0.85; }
    .ar-launch-btn:disabled { opacity: 0.7; cursor: default; }

    /* ─── Info Panel ──────────────────────────── */
    .landmark-info {
      padding: 14px 16px 16px;
      background: rgba(12,10,8,0.95);
      border-top: 1px solid rgba(184,151,58,0.12);
      flex-shrink: 0;
    }
    .landmark-name {
      font-family: var(--ff-en);
      font-size: clamp(20px, 5vw, 26px);
      color: var(--paper);
      margin-bottom: 2px;
      line-height: 1.1;
    }
    .landmark-city {
      font-size: 9px;
      color: var(--yama);
      text-transform: uppercase;
      letter-spacing: 0.15em;
    }

    /* ─── Back Button ─────────────────────────── */
    .back-btn {
      position: fixed;
      top: max(env(safe-area-inset-top), 14px);
      left: 16px;
      background: rgba(240,232,213,0.08);
      border: 1px solid rgba(240,232,213,0.18);
      color: var(--paper);
      padding: 8px 14px;
      border-radius: 20px;
      font-size: 10px;
      text-decoration: none;
      z-index: 200;
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      letter-spacing: 0.05em;
      min-height: 36px;
      display: flex;
      align-items: center;
    }

    /* ─── Scroll hint dots ────────────────────── */
    .scroll-dots {
      flex-shrink: 0;
      display: flex;
      justify-content: center;
      gap: 6px;
      padding: 10px 0 max(env(safe-area-inset-bottom), 14px);
    }
    .dot {
      width: 5px;
      height: 5px;
      border-radius: 50%;
      background: rgba(184,151,58,0.25);
      transition: background 0.3s, transform 0.3s;
    }
    .dot.active {
      background: var(--yama2);
      transform: scale(1.3);
    }
  </style>
</head>
<body>

  <a href="FunZone.html" class="back-btn">← Back</a>

  <div class="nav-header">
    <h1>Explore Japan</h1>
    <p>Augmented Reality Landmarks</p>
  </div>

  <div class="explorer-grid" id="grid"></div>

  <div class="scroll-dots" id="dots"></div>

  <script>
    const landmarks = [
      { name: "Tokyo Skytree",       city: "Tokyo",  folder: "tokyoskytree",        file: "tokyoskytree",        hasUsdz: true  },
      { name: "Japanese Torii Gate", city: "Japan",  folder: "Japanese Torii Gate", file: "Japanese Torii Gate", hasUsdz: true  },
      { name: "Japanese Castle",     city: "Japan",  folder: "japanesecastle",       file: "japanesecastle",      hasUsdz: true  },
      { name: "Nijo Castle",         city: "Kyoto",  folder: "Nijo Castle japan",    file: "Nijo Castle japan",   hasUsdz: false },
      { name: "Pagoda",              city: "Japan",  folder: "pagoda",               file: "pagoda",              hasUsdz: true  },
      { name: "Kimono Dress",        city: "Japan",  folder: "dress",                file: "dress",               hasUsdz: true  },
    ];

    const grid   = document.getElementById('grid');
    const dotsEl = document.getElementById('dots');

    const isIOS = /iPhone|iPad|iPod/i.test(navigator.userAgent) ||
                  (navigator.platform === 'MacIntel' && navigator.maxTouchPoints > 1);

    // ── Preloaded model-viewer registry ──────────────────────────────────
    // Each entry: { mv, ready: bool, error: bool }
    const preloaded = {};

    // ── Spinner HTML helper ───────────────────────────────────────────────
    const SPINNER = `<span style="display:inline-block;width:14px;height:14px;
      border:2px solid rgba(255,255,255,0.25);border-top-color:#fff;
      border-radius:50%;animation:spin 0.8s linear infinite;flex-shrink:0;"></span>`;

    // ── Create a hidden off-screen model-viewer and start loading NOW ─────
    // Staggered by index so card 0 loads first, others follow 800 ms apart.
    // This keeps bandwidth focused on the first card the user will see.
    function preloadModel(l, i) {
      const glbPath  = `ExploreJapan/${l.folder}/${l.file}.glb`;
      const usdzPath = `ExploreJapan/${l.folder}/${l.file}.usdz`;

      const mv = document.createElement('model-viewer');
      mv.setAttribute('src', glbPath);
      if (isIOS && l.hasUsdz) mv.setAttribute('ios-src', usdzPath);

      // Full AR attribute set — must be set before load so AR is primed
      mv.setAttribute('ar',                 '');
      mv.setAttribute('ar-modes',           'webxr scene-viewer quick-look');
      mv.setAttribute('ar-placement',       'floor');
      mv.setAttribute('ar-scale',           'auto');
      mv.setAttribute('camera-controls',    '');
      mv.setAttribute('shadow-intensity',   '1');
      mv.setAttribute('environment-image',  'neutral');
      mv.setAttribute('exposure',           '1.1');
      mv.setAttribute('interaction-prompt', 'none');
      mv.setAttribute('xr-environment',     '');
      // Card 0 = eager; rest = lazy so they don't block card 0
      mv.setAttribute('loading', i === 0 ? 'eager' : 'lazy');
      mv.setAttribute('reveal',  'auto');

      // Completely hidden — 1×1 pixel off-screen, no visual impact
      mv.style.cssText = 'position:fixed;width:1px;height:1px;opacity:0;pointer-events:none;top:-9999px;left:-9999px;';
      document.body.appendChild(mv);

      preloaded[i] = { mv, ready: false, error: false };

      mv.addEventListener('load', () => {
        preloaded[i].ready = true;
        // Update button to show it's ready (green dot)
        const btn = document.getElementById(`arbtn-${i}`);
        if (btn && !btn.disabled) {
          btn.innerHTML = `<span style="width:7px;height:7px;border-radius:50%;background:#4ade80;flex-shrink:0;"></span> View in Real World`;
        }
      });

      mv.addEventListener('error', () => {
        preloaded[i].error = true;
        const btn = document.getElementById(`arbtn-${i}`);
        if (btn && !btn.disabled) btn.innerHTML = '⚠️ Model unavailable';
      });
    }

    // ── Launch AR using the already-preloaded model-viewer ────────────────
    function launchAR(i, thumbWrap, btn) {
      const entry = preloaded[i];

      if (entry.error) {
        btn.innerHTML = '⚠️ Model unavailable';
        return;
      }

      if (entry.ready) {
        // ✅ Model already in memory — AR launches instantly
        entry.mv.activateAR();

        entry.mv.addEventListener('ar-status', (e) => {
          if (e.detail.status === 'failed' || e.detail.status === 'not-presenting') {
            btn.disabled = false;
            btn.innerHTML = `<span style="width:7px;height:7px;border-radius:50%;background:#4ade80;flex-shrink:0;"></span> View in Real World`;
          }
        }, { once: true });

      } else {
        // Model still downloading — show spinner and wait for load event
        btn.disabled = true;
        btn.innerHTML = `${SPINNER} Loading…`;

        entry.mv.addEventListener('load', () => {
          entry.mv.activateAR();
          btn.disabled = false;

          entry.mv.addEventListener('ar-status', (e) => {
            if (e.detail.status === 'failed' || e.detail.status === 'not-presenting') {
              btn.disabled = false;
              btn.innerHTML = `<span style="width:7px;height:7px;border-radius:50%;background:#4ade80;flex-shrink:0;"></span> View in Real World`;
            }
          }, { once: true });
        }, { once: true });

        entry.mv.addEventListener('error', () => {
          btn.disabled = false;
          btn.innerHTML = '⚠️ Failed — Tap to retry';
        }, { once: true });
      }
    }

    // ── Build cards + kick off preloads ──────────────────────────────────
    landmarks.forEach((l, i) => {
      const imgPath = `ExploreJapan/${l.folder}/${l.file}.png`;

      const card = document.createElement('div');
      card.className = 'landmark-card';
      card.dataset.index = i;

      const thumbWrap = document.createElement('div');
      thumbWrap.className = 'thumb-wrap';
      thumbWrap.innerHTML = `
        <div class="thumb-photo">
          <img src="${imgPath}" alt="${l.name}"
            loading="${i === 0 ? 'eager' : 'lazy'}"
            onerror="this.style.display='none'">
        </div>
        <div class="ar-launch-wrap">
          <button class="ar-launch-btn" id="arbtn-${i}">
            ${SPINNER} Preparing…
          </button>
        </div>`;

      const info = document.createElement('div');
      info.className = 'landmark-info';
      info.innerHTML = `
        <div class="landmark-name">${l.name}</div>
        <div class="landmark-city">${l.city}</div>`;

      card.appendChild(thumbWrap);
      card.appendChild(info);
      grid.appendChild(card);

      // Stagger preloads: card 0 immediately, each next card 800 ms later
      // so network bandwidth prioritises the first visible card
      setTimeout(() => preloadModel(l, i), i * 800);

      const btn = document.getElementById(`arbtn-${i}`);
      btn.addEventListener('click', () => {
        if (!btn.disabled) launchAR(i, thumbWrap, btn);
      });

      const dot = document.createElement('div');
      dot.className = 'dot' + (i === 0 ? ' active' : '');
      dotsEl.appendChild(dot);
    });

    // ── Scroll dots ───────────────────────────────────────────────────────
    const dots = dotsEl.querySelectorAll('.dot');
    grid.addEventListener('scroll', () => {
      const center = grid.scrollLeft + grid.clientWidth / 2;
      let closest = 0, minDist = Infinity;
      grid.querySelectorAll('.landmark-card').forEach((card, i) => {
        const cardCenter = card.offsetLeft + card.offsetWidth / 2;
        const dist = Math.abs(center - cardCenter);
        if (dist < minDist) { minDist = dist; closest = i; }
      });
      dots.forEach((d, i) => d.classList.toggle('active', i === closest));
    }, { passive: true });

    // ── Pause/resume on tab visibility ────────────────────────────────────
    document.addEventListener('visibilitychange', () => {
      Object.values(preloaded).forEach(({ mv }) => {
        if (document.hidden) { if (typeof mv.pause === 'function') mv.pause(); }
        else                  { if (typeof mv.play  === 'function') mv.play();  }
      });
    });
  </script>
</body>
</html>
