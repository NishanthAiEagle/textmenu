<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no, viewport-fit=cover">
    <title>Explore Japan · Sakura Dining</title>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="preconnect" href="https://unpkg.com">

    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@400;500&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">

    <script type="module" src="https://unpkg.com/@google/model-viewer/dist/model-viewer.min.js"></script>

    <style>
        :root {
            --ink: #080604;
            --paper: #F0E8D5;
            --yama: #B8973A;
            --yama2: #D4AE52;
            --ff-en: 'Cormorant Garamond', serif;
            --ff-ui: 'DM Sans', sans-serif;
        }

        *, *::before, *::after { box-sizing: border-box; }

        body {
            margin: 0;
            background-color: var(--ink);
            color: var(--paper);
            font-family: var(--ff-ui);
            height: 100svh;
            overflow: hidden;
            display: flex;
            flex-direction: column;
        }

        /* ─── Header ─────────────────────────────── */
        .nav-header {
            padding: max(env(safe-area-inset-top), 20px) 20px 16px;
            text-align: center;
            border-bottom: 1px solid rgba(184,151,58,0.2);
            flex-shrink: 0;
        }
        .nav-header h1 {
            font-family: var(--ff-en);
            font-size: clamp(24px, 6vw, 36px);
            margin: 0;
            color: var(--yama2);
            letter-spacing: 0.1em;
        }
        .nav-header p {
            font-size: 9px;
            text-transform: uppercase;
            letter-spacing: 0.3em;
            opacity: 0.5;
            margin: 4px 0 0;
        }

        /* ─── Scroll Grid ─────────────────────────── */
        .explorer-grid {
            flex: 1;
            display: flex;
            align-items: center;
            overflow-x: auto;
            overflow-y: hidden;
            padding: 20px 16px;
            gap: 16px;
            scroll-snap-type: x mandatory;
            -webkit-overflow-scrolling: touch;
            overscroll-behavior-x: contain;
            scrollbar-width: none;
        }
        .explorer-grid::-webkit-scrollbar { display: none; }

        /* ─── Card ────────────────────────────────── */
        .landmark-card {
            flex: 0 0 min(85vw, 360px);
            height: min(62vh, 520px);
            background: #0e0c0a;
            border: 1px solid rgba(184,151,58,0.25);
            border-radius: 14px;
            position: relative;
            scroll-snap-align: center;
            display: flex;
            flex-direction: column;
            overflow: hidden;
            will-change: transform;
            transform: translateZ(0);
        }

        /* ─── Model wrap ──────────────────────────── */
        .model-wrap {
            flex: 1;
            position: relative;
            overflow: hidden;
            background: radial-gradient(ellipse at 50% 60%, #1a150a 0%, #080604 100%);
        }

        /* Static PNG thumbnail — shown before 3D loads */
        .model-poster {
            width: 100%;
            height: 100%;
            object-fit: cover;
            display: block;
            position: absolute;
            inset: 0;
            z-index: 1;
            transition: opacity 0.4s ease;
        }
        /* Hide poster once 3D model is active */
        .model-wrap.model-active .model-poster {
            opacity: 0;
            pointer-events: none;
        }

        /*
         * model-viewer: hidden by default (poster shown instead).
         * Once user taps "View 3D", it becomes visible + interactive.
         * touch-action="none" lets model-viewer capture all touch gestures
         * including pinch-to-zoom without interference from the scroll container.
         */
        model-viewer {
            position: absolute;
            inset: 0;
            width: 100%;
            height: 100%;
            background-color: transparent;
            opacity: 0;
            pointer-events: none;
            z-index: 2;
            transition: opacity 0.4s ease;
            --poster-color: transparent;
        }
        /* When 3D mode is active, show the model-viewer and enable touch */
        .model-wrap.model-active model-viewer {
            opacity: 1;
            pointer-events: auto;
        }

        model-viewer::part(default-progress-bar) { display: none; }
        model-viewer::part(default-ar-button)     { display: none; }

        /* ─── Pinch hint overlay ──────────────────── */
        .pinch-hint {
            position: absolute;
            bottom: 10px;
            left: 50%;
            transform: translateX(-50%);
            background: rgba(8,6,4,0.7);
            border: 1px solid rgba(184,151,58,0.35);
            border-radius: 20px;
            padding: 5px 12px;
            font-size: 9px;
            letter-spacing: 0.12em;
            color: var(--yama2);
            text-transform: uppercase;
            backdrop-filter: blur(8px);
            -webkit-backdrop-filter: blur(8px);
            pointer-events: none;
            z-index: 6;
            opacity: 0;
            transition: opacity 0.4s;
            white-space: nowrap;
        }
        .model-wrap.model-active .pinch-hint {
            opacity: 1;
            animation: fadeOutHint 3s ease 2s forwards;
        }
        @keyframes fadeOutHint {
            from { opacity: 1; }
            to   { opacity: 0; }
        }

        /* ─── AR-Ready Badge ──────────────────────── */
        .ar-badge {
            position: absolute;
            top: 10px;
            right: 10px;
            background: rgba(8,6,4,0.75);
            border: 1px solid var(--yama);
            border-radius: 20px;
            padding: 4px 10px;
            font-size: 9px;
            letter-spacing: 0.15em;
            color: var(--yama2);
            text-transform: uppercase;
            opacity: 0;
            transform: translateY(-6px);
            transition: opacity 0.4s, transform 0.4s;
            backdrop-filter: blur(8px);
            -webkit-backdrop-filter: blur(8px);
            pointer-events: none;
            z-index: 5;
        }
        .ar-badge.visible {
            opacity: 1;
            transform: translateY(0);
        }

        /* ─── Loading overlay ─────────────────────── */
        .ar-loading {
            position: absolute;
            inset: 0;
            display: none;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            gap: 10px;
            background: rgba(8,6,4,0.8);
            z-index: 20;
            backdrop-filter: blur(6px);
            -webkit-backdrop-filter: blur(6px);
        }
        .ar-loading.show { display: flex; }

        .loader-ring {
            width: 38px;
            height: 38px;
            border: 2px solid rgba(184,151,58,0.15);
            border-top-color: var(--yama2);
            border-radius: 50%;
            animation: spin 0.85s linear infinite;
        }
        .loader-label {
            font-size: 9px;
            letter-spacing: 0.25em;
            text-transform: uppercase;
            color: var(--yama);
            opacity: 0.85;
        }
        .loader-bar-track {
            width: 100px;
            height: 2px;
            background: rgba(184,151,58,0.12);
            border-radius: 2px;
            overflow: hidden;
        }
        .loader-bar-fill {
            height: 100%;
            background: var(--yama2);
            width: 0%;
            border-radius: 2px;
            transition: width 0.15s ease;
        }
        @keyframes spin { to { transform: rotate(360deg); } }

        /* ─── Info Panel ──────────────────────────── */
        .landmark-info {
            padding: 16px;
            background: rgba(12,10,8,0.95);
            border-top: 1px solid rgba(184,151,58,0.12);
            flex-shrink: 0;
        }
        .landmark-name {
            font-family: var(--ff-en);
            font-size: clamp(20px, 5vw, 26px);
            color: var(--paper);
            margin-bottom: 2px;
            line-height: 1.1;
        }
        .landmark-city {
            font-size: 9px;
            color: var(--yama);
            text-transform: uppercase;
            letter-spacing: 0.15em;
            margin-bottom: 12px;
        }

        /* ─── Button row ──────────────────────────── */
        .btn-row {
            display: flex;
            gap: 8px;
        }

        /* Shared button base */
        .action-btn {
            flex: 1;
            border: none;
            padding: 13px;
            border-radius: 8px;
            font-weight: 600;
            font-size: 11px;
            letter-spacing: 0.10em;
            text-transform: uppercase;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 6px;
            min-height: 44px;
            position: relative;
            overflow: hidden;
            -webkit-tap-highlight-color: transparent;
            transition: opacity 0.2s, transform 0.15s;
        }
        .action-btn::after {
            content: '';
            position: absolute;
            inset: 0;
            background: rgba(255,255,255,0);
            transition: background 0.15s;
        }
        .action-btn:active::after { background: rgba(255,255,255,0.15); }
        .action-btn:active        { transform: scale(0.97); }
        .action-btn:disabled {
            opacity: 0.4;
            cursor: not-allowed;
            transform: none;
        }

        /* 3D view button — secondary style */
        .view3d-btn {
            background: rgba(184,151,58,0.12);
            border: 1px solid rgba(184,151,58,0.35);
            color: var(--yama2);
            flex: 0 0 auto;
            padding: 13px 14px;
        }
        /* Active state when 3D is showing */
        .view3d-btn.is-active {
            background: rgba(184,151,58,0.25);
            border-color: var(--yama);
        }

        /* AR button — primary gradient */
        .ar-btn {
            background: linear-gradient(135deg, var(--yama) 0%, var(--yama2) 100%);
            color: var(--ink);
        }

        /* ─── Back Button ─────────────────────────── */
        .back-btn {
            position: fixed;
            top: max(env(safe-area-inset-top), 14px);
            left: 16px;
            background: rgba(240,232,213,0.08);
            border: 1px solid rgba(240,232,213,0.18);
            color: var(--paper);
            padding: 8px 14px;
            border-radius: 20px;
            font-size: 10px;
            text-decoration: none;
            z-index: 200;
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
            letter-spacing: 0.05em;
            min-height: 36px;
            display: flex;
            align-items: center;
        }

        /* ─── Scroll dots ─────────────────────────── */
        .scroll-dots {
            flex-shrink: 0;
            display: flex;
            justify-content: center;
            gap: 6px;
            padding: 10px 0 max(env(safe-area-inset-bottom), 14px);
        }
        .dot {
            width: 5px; height: 5px;
            border-radius: 50%;
            background: rgba(184,151,58,0.25);
            transition: background 0.3s, transform 0.3s;
        }
        .dot.active {
            background: var(--yama2);
            transform: scale(1.3);
        }
    </style>
</head>
<body>

    <a href="FunZone.html" class="back-btn">← Back</a>

    <div class="nav-header">
        <h1>Explore Japan</h1>
        <p>Augmented Reality Landmarks</p>
    </div>

    <div class="explorer-grid" id="grid"></div>
    <div class="scroll-dots" id="dots"></div>

    <script>
        const landmarks = [
            { name: "Tokyo Skytree",       city: "Tokyo",  folder: "tokyoskytree",       file: "tokyoskytree",        hasUsdz: true  },
            { name: "Japanese Torii Gate", city: "Japan",  folder: "Japanese Torii Gate", file: "Japanese Torii Gate", hasUsdz: true  },
            { name: "Japanese Castle",     city: "Japan",  folder: "japanesecastle",       file: "japanesecastle",      hasUsdz: true  },
            { name: "Nijo Castle",         city: "Kyoto",  folder: "Nijo Castle japan",    file: "Nijo Castle japan",   hasUsdz: false },
            { name: "Pagoda",              city: "Japan",  folder: "pagoda",               file: "pagoda",              hasUsdz: true  },
            { name: "Kimono Dress",        city: "Japan",  folder: "dress",                file: "dress",               hasUsdz: true  },
        ];

        const grid   = document.getElementById('grid');
        const dotsEl = document.getElementById('dots');

        const isIOS = /iPhone|iPad|iPod/i.test(navigator.userAgent) ||
                      (navigator.platform === 'MacIntel' && navigator.maxTouchPoints > 1);

        landmarks.forEach((l, i) => {
            const base     = `ExploreJapan/${l.folder}/${l.file}`;
            const glbPath  = `${base}.glb`;
            const usdzPath = `${base}.usdz`;
            const pngPath  = `${base}.png`;

            const card = document.createElement('div');
            card.className = 'landmark-card';
            card.dataset.index = i;

            card.innerHTML = `
                <div class="model-wrap" id="wrap-${i}">

                    <!-- Static PNG thumbnail -->
                    <img
                        class="model-poster"
                        src="${pngPath}"
                        alt="${l.name}"
                        loading="${i === 0 ? 'eager' : 'lazy'}"
                    >

                    <!--
                        touch-action="none" — lets model-viewer own ALL touch input,
                        enabling pinch-to-zoom without browser interference.
                        camera-controls enables orbit + pinch-to-zoom by default.
                        min-camera-orbit / max-camera-orbit constrain zoom range.
                    -->
                    <model-viewer
                        id="mv-${i}"
                        src="${glbPath}"
                        ${isIOS && l.hasUsdz ? `ios-src="${usdzPath}"` : ''}
                        ar
                        ar-modes="${isIOS ? 'quick-look webxr' : 'scene-viewer webxr'}"
                        ar-placement="floor"
                        ar-scale="fixed"
                        loading="${i === 0 ? 'eager' : 'lazy'}"
                        reveal="interaction"
                        environment-image="neutral"
                        shadow-intensity="1.2"
                        shadow-softness="0.8"
                        exposure="1.1"
                        camera-controls
                        touch-action="none"
                        min-camera-orbit="auto auto 5%"
                        max-camera-orbit="auto auto 200%"
                        interaction-prompt="none"
                    ></model-viewer>

                    <!-- Spinner shown while GLB loads -->
                    <div class="ar-loading" id="arload-${i}">
                        <div class="loader-ring"></div>
                        <div class="loader-bar-track">
                            <div class="loader-bar-fill" id="bar-${i}"></div>
                        </div>
                        <div class="loader-label" id="lbl-${i}">Loading model…</div>
                    </div>

                    <div class="ar-badge" id="badge-${i}">✦ AR Ready</div>

                    <!-- Pinch hint shown briefly when 3D view activates -->
                    <div class="pinch-hint" id="hint-${i}">⟺ Pinch to zoom · Drag to rotate</div>
                </div>

                <div class="landmark-info">
                    <div class="landmark-name">${l.name}</div>
                    <div class="landmark-city">${l.city}</div>
                    <div class="btn-row">
                        <!-- Toggle 3D view with pinch-to-zoom -->
                        <button
                            class="action-btn view3d-btn"
                            id="v3dbtn-${i}"
                            onclick="toggle3D(${i})"
                            title="View 3D model with pinch-to-zoom"
                        >
                            ⬡ 3D
                        </button>
                        <!-- Launch AR -->
                        <button
                            class="action-btn ar-btn"
                            id="arbtn-${i}"
                            onclick="launchAR(${i})"
                        >
                            <span>🪐</span> View in Real World
                        </button>
                    </div>
                </div>
            `;

            grid.appendChild(card);

            const dot = document.createElement('div');
            dot.className = 'dot' + (i === 0 ? ' active' : '');
            dotsEl.appendChild(dot);
        });

        // ─── Per-card state ────────────────────────────────────────────────────
        const state = {};

        requestAnimationFrame(() => {
            landmarks.forEach((l, i) => {
                const mv      = document.getElementById(`mv-${i}`);
                const arload  = document.getElementById(`arload-${i}`);
                const bar     = document.getElementById(`bar-${i}`);
                const lbl     = document.getElementById(`lbl-${i}`);
                const badge   = document.getElementById(`badge-${i}`);
                const arbtn   = document.getElementById(`arbtn-${i}`);
                const v3dbtn  = document.getElementById(`v3dbtn-${i}`);
                const wrap    = document.getElementById(`wrap-${i}`);

                state[i] = {
                    mv, arload, bar, lbl, badge, arbtn, v3dbtn, wrap,
                    ready: false, loading: false, showing3D: false
                };

                // Download progress
                mv.addEventListener('progress', (e) => {
                    const pct = Math.round(e.detail.totalProgress * 100);
                    if (bar) bar.style.width = pct + '%';
                    if (lbl) lbl.textContent = `Loading… ${pct}%`;
                });

                // Model loaded
                mv.addEventListener('load', () => {
                    const s = state[i];
                    s.ready   = true;
                    s.loading = false;
                    arload.classList.remove('show');
                    badge.classList.add('visible');

                    // If user tapped 3D while loading → activate 3D view now
                    if (s.pending3D) {
                        s.pending3D = false;
                        activate3DView(i);
                    }
                    // If user tapped AR while loading → launch AR now
                    if (s.pendingAR) {
                        s.pendingAR = false;
                        mv.activateAR();
                    }
                });

                mv.addEventListener('error', () => {
                    const s = state[i];
                    s.loading = false;
                    arload.classList.remove('show');
                    if (lbl) lbl.textContent = 'Model unavailable';
                    arbtn.disabled = true;
                    v3dbtn.disabled = true;
                    arbtn.textContent = 'Unavailable';
                });
            });
        });

        // ─── Activate 3D view ──────────────────────────────────────────────────
        // Makes model-viewer visible + interactive so pinch-to-zoom works
        function activate3DView(i) {
            const s = state[i];
            s.showing3D = true;
            s.wrap.classList.add('model-active');
            s.v3dbtn.classList.add('is-active');
            s.v3dbtn.innerHTML = '✕ 2D';

            // Prevent the horizontal scroll container from stealing scroll/pinch
            // while the user is interacting with the 3D model
            s.wrap.addEventListener('touchstart', stopScrollPropagation, { passive: false });
        }

        // ─── Deactivate 3D view ────────────────────────────────────────────────
        function deactivate3DView(i) {
            const s = state[i];
            s.showing3D = false;
            s.wrap.classList.remove('model-active');
            s.v3dbtn.classList.remove('is-active');
            s.v3dbtn.innerHTML = '⬡ 3D';
            s.wrap.removeEventListener('touchstart', stopScrollPropagation);
        }

        // Prevent parent scroll container from intercepting touches on the model
        function stopScrollPropagation(e) {
            // Allow single-finger vertical scroll on the grid to still work
            // but block the horizontal scroll snap so pinch is not interrupted
            if (e.touches.length > 1) {
                e.stopPropagation();
            }
        }

        // ─── Toggle 3D / back to thumbnail ────────────────────────────────────
        function toggle3D(i) {
            const s = state[i];

            if (s.showing3D) {
                deactivate3DView(i);
                return;
            }

            if (s.ready) {
                activate3DView(i);
            } else if (!s.loading) {
                s.loading   = true;
                s.pending3D = true;
                s.mv.setAttribute('loading', 'eager');
                s.arload.classList.add('show');
            } else {
                s.pending3D = true;
            }
        }

        // ─── AR launcher (must be synchronous in tap gesture) ─────────────────
        function launchAR(i) {
            const s = state[i];
            if (!s) return;

            if (s.ready) {
                s.mv.activateAR();
            } else if (!s.loading) {
                s.loading   = true;
                s.pendingAR = true;
                s.mv.setAttribute('loading', 'eager');
                s.arload.classList.add('show');
            } else {
                s.pendingAR = true;
            }
        }

        // ─── Scroll dot sync ──────────────────────────────────────────────────
        const dots = dotsEl.querySelectorAll('.dot');

        grid.addEventListener('scroll', () => {
            const center = grid.scrollLeft + grid.clientWidth / 2;
            let closest = 0, minDist = Infinity;
            grid.querySelectorAll('.landmark-card').forEach((card, ci) => {
                const dist = Math.abs((card.offsetLeft + card.offsetWidth / 2) - center);
                if (dist < minDist) { minDist = dist; closest = ci; }
            });
            dots.forEach((d, di) => d.classList.toggle('active', di === closest));
        }, { passive: true });
    </script>
</body>
</html>
