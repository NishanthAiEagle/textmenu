<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no, viewport-fit=cover">
    <title>Explore Japan · Sakura Dining</title>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="preconnect" href="https://unpkg.com">

    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@400;500&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">

    <script type="module" src="https://unpkg.com/@google/model-viewer/dist/model-viewer.min.js"></script>

    <style>
        :root {
            --ink: #080604;
            --paper: #F0E8D5;
            --yama: #B8973A;
            --yama2: #D4AE52;
            --beni: #7A2E1E;
            --ff-en: 'Cormorant Garamond', serif;
            --ff-ui: 'DM Sans', sans-serif;
        }

        *, *::before, *::after { box-sizing: border-box; }

        body {
            margin: 0;
            background-color: var(--ink);
            color: var(--paper);
            font-family: var(--ff-ui);
            height: 100svh;
            overflow: hidden;
            display: flex;
            flex-direction: column;
        }

        /* ─── Header ─────────────────────────────── */
        .nav-header {
            padding: max(env(safe-area-inset-top), 20px) 20px 16px;
            text-align: center;
            border-bottom: 1px solid rgba(184,151,58,0.2);
            flex-shrink: 0;
        }

        .nav-header h1 {
            font-family: var(--ff-en);
            font-size: clamp(24px, 6vw, 36px);
            margin: 0;
            color: var(--yama2);
            letter-spacing: 0.1em;
        }

        .nav-header p {
            font-size: 9px;
            text-transform: uppercase;
            letter-spacing: 0.3em;
            opacity: 0.5;
            margin: 4px 0 0;
        }

        /* ─── Scroll Grid ─────────────────────────── */
        .explorer-grid {
            flex: 1;
            display: flex;
            align-items: center;
            overflow-x: auto;
            overflow-y: hidden;
            padding: 20px 16px;
            gap: 16px;
            scroll-snap-type: x mandatory;
            -webkit-overflow-scrolling: touch;
            overscroll-behavior-x: contain;
            scrollbar-width: none;
        }
        .explorer-grid::-webkit-scrollbar { display: none; }

        /* ─── Card ────────────────────────────────── */
        .landmark-card {
            flex: 0 0 min(85vw, 360px);
            height: min(62vh, 520px);
            background: #0e0c0a;
            border: 1px solid rgba(184,151,58,0.25);
            border-radius: 14px;
            position: relative;
            scroll-snap-align: center;
            display: flex;
            flex-direction: column;
            overflow: hidden;
            will-change: transform;
            transform: translateZ(0);
        }

        /* ─── Thumbnail Image ─────────────────────── */
        .thumb-wrap {
            flex: 1;
            position: relative;
            overflow: hidden;
            background: radial-gradient(ellipse at 50% 60%, #1a150a 0%, #080604 100%);
        }

        .thumb-wrap img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            display: block;
        }

        /* ─── Info Panel ──────────────────────────── */
        .landmark-info {
            padding: 16px;
            background: rgba(12,10,8,0.95);
            border-top: 1px solid rgba(184,151,58,0.12);
            flex-shrink: 0;
        }

        .landmark-name {
            font-family: var(--ff-en);
            font-size: clamp(20px, 5vw, 26px);
            color: var(--paper);
            margin-bottom: 2px;
            line-height: 1.1;
        }

        .landmark-city {
            font-size: 9px;
            color: var(--yama);
            text-transform: uppercase;
            letter-spacing: 0.15em;
            margin-bottom: 12px;
        }

        /* ─── AR Button ───────────────────────────── */
        .ar-btn {
            width: 100%;
            background: linear-gradient(135deg, var(--yama) 0%, var(--yama2) 100%);
            border: none;
            padding: 13px;
            border-radius: 8px;
            color: var(--ink);
            font-weight: 600;
            font-size: 11px;
            letter-spacing: 0.12em;
            text-transform: uppercase;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            transition: opacity 0.2s, transform 0.15s;
            min-height: 44px;
            position: relative;
            overflow: hidden;
        }

        .ar-btn::after {
            content: '';
            position: absolute;
            inset: 0;
            background: rgba(255,255,255,0);
            transition: background 0.15s;
        }

        .ar-btn:active::after { background: rgba(255,255,255,0.15); }
        .ar-btn:active { transform: scale(0.97); }

        /* ─── Back Button ─────────────────────────── */
        .back-btn {
            position: fixed;
            top: max(env(safe-area-inset-top), 14px);
            left: 16px;
            background: rgba(240,232,213,0.08);
            border: 1px solid rgba(240,232,213,0.18);
            color: var(--paper);
            padding: 8px 14px;
            border-radius: 20px;
            font-size: 10px;
            text-decoration: none;
            z-index: 200;
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
            letter-spacing: 0.05em;
            min-height: 36px;
            display: flex;
            align-items: center;
        }

        /* ─── Scroll hint dots ────────────────────── */
        .scroll-dots {
            flex-shrink: 0;
            display: flex;
            justify-content: center;
            gap: 6px;
            padding: 10px 0 max(env(safe-area-inset-bottom), 14px);
        }

        .dot {
            width: 5px;
            height: 5px;
            border-radius: 50%;
            background: rgba(184,151,58,0.25);
            transition: background 0.3s, transform 0.3s;
        }

        .dot.active {
            background: var(--yama2);
            transform: scale(1.3);
        }
    </style>
</head>
<body>

    <a href="FunZone.html" class="back-btn">← Back</a>

    <div class="nav-header">
        <h1>Explore Japan</h1>
        <p>Augmented Reality Landmarks</p>
    </div>

    <div class="explorer-grid" id="grid"></div>

    <div class="scroll-dots" id="dots"></div>

    <script>
        const landmarks = [
            { name: "Tokyo Skytree",       city: "Tokyo",  folder: "tokyoskytree",       file: "tokyoskytree",        hasUsdz: true  },
            { name: "Japanese Torii Gate", city: "Japan",  folder: "Japanese Torii Gate", file: "Japanese Torii Gate", hasUsdz: true  },
            { name: "Japanese Castle",     city: "Japan",  folder: "japanesecastle",       file: "japanesecastle",      hasUsdz: true  },
            { name: "Nijo Castle",         city: "Kyoto",  folder: "Nijo Castle japan",    file: "Nijo Castle japan",   hasUsdz: false },
            { name: "Pagoda",              city: "Japan",  folder: "pagoda",               file: "pagoda",              hasUsdz: true  },
            { name: "Kimono Dress",        city: "Japan",  folder: "dress",                file: "dress",               hasUsdz: true  },
        ];

        const grid   = document.getElementById('grid');
        const dotsEl = document.getElementById('dots');

        const isIOS = /iPhone|iPad|iPod/i.test(navigator.userAgent) ||
                      (navigator.platform === 'MacIntel' && navigator.maxTouchPoints > 1);

        // ── Preload ALL models silently on page load ───────────────────────────
        const preloaded = {};

        function preloadModel(l, i) {
            const mv = document.createElement('model-viewer');
            mv.id = `mv-ar-${i}`;

            // ── Src ────────────────────────────────────────────────────────────
            mv.setAttribute('src', `ExploreJapan/${l.folder}/${l.file}.glb`);
            if (isIOS && l.hasUsdz) mv.setAttribute('ios-src', `ExploreJapan/${l.folder}/${l.file}.usdz`);

            // ── AR core ────────────────────────────────────────────────────────
            mv.setAttribute('ar', '');
            mv.setAttribute('ar-modes', 'webxr scene-viewer quick-look');
            mv.setAttribute('ar-placement', 'floor');
            mv.setAttribute('ar-scale', 'auto');            // pinch to resize in AR
            mv.setAttribute('camera-controls', '');         // full gesture support
            mv.setAttribute('touch-action', 'none');        // model-viewer owns all touches
            mv.setAttribute('interaction-prompt', 'none');
            mv.setAttribute('shadow-intensity', '1');
            mv.setAttribute('exposure', '1.1');

            // ── Depth + environment estimation ────────────────────────────────
            mv.setAttribute('xr-environment', '');                  // real-world depth understanding
            mv.setAttribute('environment-image', 'neutral');        // realistic lighting blend
            mv.setAttribute('ar-environment-estimation', '');       // match real-world lighting

            // ── Eager load → model in memory before button tap ────────────────
            mv.setAttribute('loading', 'eager');
            mv.setAttribute('reveal', 'auto');

            // ── Hidden off-screen ──────────────────────────────────────────────
            mv.style.cssText = 'position:fixed;width:1px;height:1px;opacity:0;pointer-events:none;top:0;left:0;';
            document.body.appendChild(mv);

            preloaded[i] = mv;

            mv.addEventListener('load', () => {
                preloaded[i].ready = true;
                console.log(`✅ Preloaded: ${l.name}`);
            });

            mv.addEventListener('error', () => {
                console.warn(`⚠️ Failed to preload: ${l.name}`);
            });
        }

        landmarks.forEach((l, i) => {
            const imgPath = `ExploreJapan/${l.folder}/${l.file}.png`;

            const card = document.createElement('div');
            card.className = 'landmark-card';
            card.dataset.index = i;

            card.innerHTML = `
                <div class="thumb-wrap">
                    <img src="${imgPath}" alt="${l.name}" loading="${i === 0 ? 'eager' : 'lazy'}">
                </div>
                <div class="landmark-info">
                    <div class="landmark-name">${l.name}</div>
                    <div class="landmark-city">${l.city}</div>
                    <button class="ar-btn" id="arbtn-${i}">
                        <span>🪐</span> View in Real World
                    </button>
                </div>
            `;

            grid.appendChild(card);

            // ── Start preloading immediately in background ─────────────────────
            preloadModel(l, i);

            const btn = card.querySelector(`#arbtn-${i}`);
            btn.addEventListener('click', () => {
                const mv = preloaded[i];
                if (mv) {
                    // Model already in memory → instant AR launch
                    mv.activateAR();
                }
            });

            const dot = document.createElement('div');
            dot.className = 'dot' + (i === 0 ? ' active' : '');
            dot.dataset.index = i;
            dotsEl.appendChild(dot);
        });

        const dots = dotsEl.querySelectorAll('.dot');

        grid.addEventListener('scroll', () => {
            const center = grid.scrollLeft + grid.clientWidth / 2;
            let closest = 0, minDist = Infinity;
            grid.querySelectorAll('.landmark-card').forEach((card, i) => {
                const cardCenter = card.offsetLeft + card.offsetWidth / 2;
                const dist = Math.abs(center - cardCenter);
                if (dist < minDist) { minDist = dist; closest = i; }
            });
            dots.forEach((d, i) => d.classList.toggle('active', i === closest));
        }, { passive: true });
    </script>
</body>
</html>